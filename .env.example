# OpenRouter API Key (used for AI article generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=BugWorld - Entomology Blog
NEXT_PUBLIC_SITE_DESCRIPTION=Explore the hidden world of insects. Expert articles on entomology, insect behavior, ecology, and more.

# Newsletter (optional - add your Mailchimp/ConvertKit details)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=

# Google AdSense (optional - add when approved)
NEXT_PUBLIC_ADSENSE_ID=

# Cron Job Secret (used to authenticate scheduled article generation)
CRON_SECRET=change-me-to-a-random-secret-string

# Facebook Auto-Posting
# Get these from: https://developers.facebook.com → Your App → Graph API Explorer
FACEBOOK_PAGE_ID=your_page_id_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here
